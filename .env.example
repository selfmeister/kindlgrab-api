# OpenAI API Key (required)
OPENAI_API_KEY=sk-your-openai-api-key-here

# RAG API Key for authentication (generate a secure random string)
# You can generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
RAG_API_KEY=your-secure-api-key-here

# Server Configuration
PORT=8000
HOST=127.0.0.1
ALLOWED_HOSTS=rag.elicitiq.com,localhost,127.0.0.1

# Optional: Debug mode
DEBUG=false
